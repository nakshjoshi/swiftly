// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ExperienceType {
  INTERNSHIP
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  RESEARCH
  VOLUNTEER
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  fullName     String?
  phone        String?
  avatarUrl    String?
  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authAccount AuthAccount[]
  resume      Resume[]
  sessions    Session[]
}

model AuthAccount {
  id     String @id @default(uuid())
  userId String

  user User @relation(fields: [userId], references: [id])

  provider     String
  providerId   String?
  passwordHash String?
  createdAt    DateTime @default(now())

  @@unique([userId, provider])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  device       String?
  ip           String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id                String  @id @default(uuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id])
  title             String? @default("Resume-1")
  firstName         String?
  middleName        String?
  lastName          String?
  country           String?
  phoneNumber       String?
  resumeEmail       String?
  linkedIn          String?
  github            String?
  personalPortfolio String?
  leetCode          String?
  codingProfile2    String?
  codingProfile3    String?
  summary           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  education    Education[]
  experience   Experience[]
  projects     Projects[]
  skills       Skills[]
  achievements Achievements[]
  pors         Por[]
  publications Publications[]

  @@index([userId])
}

model Education {
  id       String @id @default(uuid())
  resumeId String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  instituteName String?
  level         String?
  startDate     String?
  endDate       String?
  location      String?
  degree        String?
  branch        String?
  grade         String?

  @@index([resumeId])
}

model Experience {
  id       String @id @default(uuid())
  resumeId String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  companyName String?
  location    String?
  type        ExperienceType
  startDate   String?
  endDate     String?
  position    String?
  description String?
  proofLink   String?

  @@index([resumeId])
}

model Projects {
  id       String @id @default(uuid())
  resumeId String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  projectName String?
  techStack   String[]
  description String?
  githubLink  String?
  liveLink    String?
  startDate   String?
  endDate     String?

  @@index([resumeId])
}

model Skills {
  id       String @id @default(uuid())
  resumeId String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  name     String?
  category String?

  @@index([resumeId])
}

model Achievements {
  id       String @id @default(uuid())
  resumeId String

  resume      Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  title       String?
  org         String?
  date        String?
  description String?

  @@index([resumeId])
}

model Por {
  id       String @id @default(uuid())
  resumeId String

  resume      Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  title       String?
  org         String?
  startDate   String?
  endDate     String?
  description String?

  @@index([resumeId])
}

model Publications {
  id       String @id @default(uuid())
  resumeId String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  authors         String?
  title           String?
  conference      String?
  place           String?
  publicationDate String?
  description     String?

  @@index([resumeId])
}
